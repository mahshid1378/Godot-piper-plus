[configuration]
entry_symbol = "piper_plus_library_init"
compatibility_minimum = "4.4"
reloadable = false

[libraries]
macos.debug = "res://addons/piper_plus/bin/libpiper_plus.macos.template_debug.arm64.dylib"
macos.release = "res://addons/piper_plus/bin/libpiper_plus.macos.template_release.arm64.dylib"
windows.debug.x86_64 = "res://addons/piper_plus/bin/libpiper_plus.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://addons/piper_plus/bin/libpiper_plus.windows.template_release.x86_64.dll"
linux.debug.x86_64 = "res://addons/piper_plus/bin/libpiper_plus.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://addons/piper_plus/bin/libpiper_plus.linux.template_release.x86_64.so"
android.debug.arm64 = "res://addons/piper_plus/bin/libpiper_plus.android.template_debug.arm64.so"
android.release.arm64 = "res://addons/piper_plus/bin/libpiper_plus.android.template_release.arm64.so"
ios.debug = "res://addons/piper_plus/bin/libpiper_plus.ios.template_debug.arm64.a"
ios.release = "res://addons/piper_plus/bin/libpiper_plus.ios.template_release.arm64.a"
web.debug.threads.wasm32 = "res://addons/piper_plus/bin/libpiper_plus.web.template_debug.wasm32.wasm"
web.release.threads.wasm32 = "res://addons/piper_plus/bin/libpiper_plus.web.template_release.wasm32.wasm"
web.debug.wasm32 = "res://addons/piper_plus/bin/libpiper_plus.web.template_debug.wasm32.nothreads.wasm"
web.release.wasm32 = "res://addons/piper_plus/bin/libpiper_plus.web.template_release.wasm32.nothreads.wasm"

[dependencies]
windows.debug.x86_64 = {"res://addons/piper_plus/bin/onnxruntime.dll": "", "res://addons/piper_plus/bin/onnxruntime_providers_shared.dll": ""}
windows.release.x86_64 = {"res://addons/piper_plus/bin/onnxruntime.dll": "", "res://addons/piper_plus/bin/onnxruntime_providers_shared.dll": ""}
linux.debug.x86_64 = {"res://addons/piper_plus/bin/libonnxruntime.linux.x86_64.so": ""}
linux.release.x86_64 = {"res://addons/piper_plus/bin/libonnxruntime.linux.x86_64.so": ""}
macos.debug = {"res://addons/piper_plus/bin/libonnxruntime.macos.arm64.dylib": ""}
macos.release = {"res://addons/piper_plus/bin/libonnxruntime.macos.arm64.dylib": ""}
android.debug.arm64 = {"res://addons/piper_plus/bin/libonnxruntime.android.arm64.so": ""}
android.release.arm64 = {"res://addons/piper_plus/bin/libonnxruntime.android.arm64.so": ""}
ios.debug = {
  "res://addons/piper_plus/bin/libgodot-cpp.ios.template_debug.arm64.a": "",
  "res://addons/piper_plus/bin/libonnxruntime.a": "",
  "res://addons/piper_plus/bin/libopenjtalk.a": "",
  "res://addons/piper_plus/bin/libmecab.a": "",
  "res://addons/piper_plus/bin/libHTSEngine.a": ""
}
ios.release = {
  "res://addons/piper_plus/bin/libgodot-cpp.ios.template_release.arm64.a": "",
  "res://addons/piper_plus/bin/libonnxruntime.a": "",
  "res://addons/piper_plus/bin/libopenjtalk.a": "",
  "res://addons/piper_plus/bin/libmecab.a": "",
  "res://addons/piper_plus/bin/libHTSEngine.a": ""
}
